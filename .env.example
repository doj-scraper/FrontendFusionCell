# Runtime connection used by the Next.js app and Prisma Client queries
DATABASE_URL="postgresql://<user>:<password>@<pooled-host>/<database>?sslmode=require&channel_binding=require"

# Direct Postgres connection for Prisma CLI commands
# If your provider does not require a separate direct URL, set DIRECT_URL equal to DATABASE_URL.
DIRECT_URL="postgresql://<user>:<password>@<direct-host>/<database>?sslmode=require&channel_binding=require"

# Base application URL
NEXTAUTH_URL="http://localhost:3000"

# Generate a long random value: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Stripe server-side API key
STRIPE_SECRET_KEY="sk_test_replace_me"

# Stripe publishable key for client integrations
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace_me"

# Stripe webhook signing secret (for Phase 4 webhook handling)
STRIPE_WEBHOOK_SECRET="whsec_replace_me"

# Node environment mode
NODE_ENV="development"
