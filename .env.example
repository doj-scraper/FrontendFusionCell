# Runtime connection used by the Next.js app and Prisma Client queries.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fusioncell?sslmode=require"

# Direct Postgres connection for Prisma CLI commands (migrate/db push/introspection).
# For Neon this should typically point to the non-pooled endpoint.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/fusioncell?sslmode=require"

# NextAuth configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
