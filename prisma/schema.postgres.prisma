// FusionCell Prisma Schema v3.0 - PostgreSQL Version
// Production-ready schema for wholesale cell phone repair parts
// Optimized for PostgreSQL with Decimal precision for money
//
// TO USE: Rename this file to schema.prisma and update DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// PRODUCT CATALOG LAYER
// ============================================

/// Brand represents phone manufacturers (Apple, Samsung, Motorola, etc.)
model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  logo        String?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  devices     Device[]

  @@index([slug])
  @@index([isActive])
  @@map("brands")
}

/// Device represents specific phone models
model Device {
  id          String   @id @default(cuid())
  brandId     String
  name        String
  slug        String   @unique
  modelNumber String?
  image       String?
  releaseYear Int?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  parts       Part[]
  compatibilities PartDeviceCompatibility[]

  @@index([brandId])
  @@index([slug])
  @@index([releaseYear])
  @@map("devices")
}

/// PartCategory represents types of parts (Screen, Battery, Charging Port, etc.)
model PartCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parts       Part[]

  @@index([slug])
  @@map("part_categories")
}

/// Part represents a product in the catalog (parent for variants)
model Part {
  id           String   @id @default(cuid())
  deviceId     String
  categoryId   String
  name         String
  slug         String   @unique
  description  String?  @db.Text
  isActive     Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  device       Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  category     PartCategory  @relation(fields: [categoryId], references: [id])
  variants     PartVariant[]
  images       PartImage[]
  compatibilities PartDeviceCompatibility[]

  @@index([deviceId])
  @@index([categoryId])
  @@index([slug])
  @@index([isFeatured])
  @@map("parts")
}

/// PartVariant represents specific variations of a part (quality, color, etc.)
model PartVariant {
  id           String   @id @default(cuid())
  partId       String
  sku          String   @unique
  name         String   // e.g., "OEM Black", "Aftermarket White"
  slug         String   @unique
  quality      String?  // OEM, Aftermarket, Premium, Refurbished
  color        String?
  weight       Decimal? @db.Decimal(8, 2) // in grams
  barcode      String?
  
  // Pricing - using Decimal for exact money precision
  price        Decimal  @db.Decimal(10, 2) // Wholesale price
  comparePrice Decimal? @db.Decimal(10, 2) // MSRP or compare at price
  cost         Decimal? @db.Decimal(10, 2) // Cost price (internal)
  
  minOrderQty  Int      @default(5)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  part         Part        @relation(fields: [partId], references: [id], onDelete: Cascade)
  inventory    Inventory?
  orderItems   OrderItem[]
  movements    InventoryMovement[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([partId])
  @@index([sku])
  @@index([quality])
  @@index([isActive])
  @@index([price])
  @@map("part_variants")
}

/// PartImage for multiple product images
model PartImage {
  id        String   @id @default(cuid())
  partId    String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  part      Part     @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([partId])
  @@map("part_images")
}

/// PartDeviceCompatibility for parts that work across multiple devices
model PartDeviceCompatibility {
  id       String @id @default(cuid())
  partId   String
  deviceId String
  notes    String? @db.Text // e.g., "Requires adapter"

  part     Part   @relation(fields: [partId], references: [id], onDelete: Cascade)
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([partId, deviceId])
  @@index([partId])
  @@index([deviceId])
  @@map("part_device_compatibility")
}

// ============================================
// INVENTORY LAYER
// ============================================

/// Inventory tracks stock levels at variant level
model Inventory {
  id             String    @id @default(cuid())
  variantId      String    @unique
  quantity       Int       @default(0)
  reserved       Int       @default(0) // Reserved for pending orders
  reorderPoint   Int       @default(10)
  location       String?   // Warehouse location/bin
  lastRestock    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  variant        PartVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([location])
  @@map("inventory")
}

/// InventoryMovement logs all stock changes
model InventoryMovement {
  id            String    @id @default(cuid())
  variantId     String
  change        Int       // Positive for incoming, negative for outgoing
  reason        String    // restock, sale, damage, return, adjustment, reserved, released
  reference     String?   // Order ID, PO ID, etc.
  notes         String?   @db.Text
  createdBy     String?   // User ID or system
  createdAt     DateTime  @default(now())

  variant       PartVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([createdAt])
  @@index([reason])
  @@map("inventory_movements")
}

// ============================================
// SUPPLIER LAYER
// ============================================

/// Supplier represents parts suppliers
model Supplier {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  contactName String?
  email       String?
  phone       String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  country     String    @default("US")
  website     String?
  notes       String?   @db.Text
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([slug])
  @@index([isActive])
  @@map("suppliers")
}

/// PurchaseOrder for tracking inventory purchases from suppliers
model PurchaseOrder {
  id            String    @id @default(cuid())
  supplierId    String
  poNumber      String    @unique
  status        String    @default("draft") // draft, submitted, received, cancelled
  orderDate     DateTime  @default(now())
  expectedDate  DateTime?
  receivedDate  DateTime?
  subtotal      Decimal   @db.Decimal(12, 2) @default(0)
  shipping      Decimal   @db.Decimal(10, 2) @default(0)
  tax           Decimal   @db.Decimal(10, 2) @default(0)
  total         Decimal   @db.Decimal(12, 2) @default(0)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  supplier      Supplier          @relation(fields: [supplierId], references: [id])
  items         PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
  @@index([poNumber])
  @@map("purchase_orders")
}

/// PurchaseOrderItem for line items in purchase orders
model PurchaseOrderItem {
  id            String    @id @default(cuid())
  purchaseOrderId String
  variantId     String
  quantity      Int
  unitCost      Decimal   @db.Decimal(10, 2)
  totalCost     Decimal   @db.Decimal(12, 2)
  receivedQty   Int       @default(0)
  createdAt     DateTime  @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant       PartVariant   @relation(fields: [variantId], references: [id])

  @@index([purchaseOrderId])
  @@index([variantId])
  @@map("purchase_order_items")
}

// ============================================
// CUSTOMER LAYER
// ============================================

/// User accounts for customers
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  name          String?
  company       String?
  phone         String?
  taxId         String?   // For wholesale accounts
  address       String?
  city          String?
  state         String?
  zipCode       String?
  country       String   @default("US")
  role          String   @default("customer") // customer, admin, manager
  isActive      Boolean  @default(true)
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

// ============================================
// ORDER LAYER
// ============================================

/// Order for checkout
model Order {
  id              String   @id @default(cuid())
  userId          String?
  orderNumber     String   @unique
  status          String   @default("pending") // pending, processing, shipped, delivered, cancelled
  subtotal        Decimal  @db.Decimal(12, 2)
  tax             Decimal  @db.Decimal(10, 2) @default(0)
  shipping        Decimal  @db.Decimal(10, 2) @default(0)
  discount        Decimal  @db.Decimal(10, 2) @default(0)
  total           Decimal  @db.Decimal(12, 2)
  
  // Shipping address
  shippingName    String?
  shippingCompany String?
  shippingAddr    String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?
  shippingPhone   String?
  
  // Billing address
  billingName     String?
  billingCompany  String?
  billingAddr     String?
  billingCity     String?
  billingState    String?
  billingZip      String?
  billingCountry  String?
  
  // Tracking
  trackingNumber  String?
  carrier         String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User?    @relation(fields: [userId], references: [id])
  items           OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
  @@map("orders")
}

/// Order items with snapshot data
model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  variantId   String
  
  // Snapshot data (captured at order time)
  sku         String
  name        String
  quality     String?
  color       String?
  price       Decimal  @db.Decimal(10, 2) // Price at time of order
  quantity    Int
  total       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     PartVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

// ============================================
// SETTINGS & CONFIGURATION
// ============================================

/// SiteSetting for configurable values
model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@map("site_settings")
}
