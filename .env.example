# Runtime connection used by the Next.js app and Prisma Client queries
DATABASE_URL="postgresql://<user>:<password>@<pooled-host>/<database>?sslmode=require&channel_binding=require"

# Direct Postgres connection for Prisma CLI commands
DIRECT_URL="postgresql://<user>:<password>@<direct-host>/<database>?sslmode=require&channel_binding=require"

# Replace with your Vercel production URL after deployment
# Example: https://your-project.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Generate a long random value: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
